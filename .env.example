# PlayBeacon Mobile App Configuration
# ===========================================
# SETUP INSTRUCTIONS:
# 1. Copy this file to .env
# 2. Fill in your actual values
# 3. NEVER commit .env to version control
# ===========================================

# ===========================================
# API Configuration
# ===========================================

# Crawler Service API URL
# Development: Use your local or dev Cloud Run URL
# Production: Use your production Cloud Run URL
EXPO_PUBLIC_API_BASE_URL=https://your-api-url.a.run.app/api

# ===========================================
# Firebase Configuration
# ===========================================
# Get these values from Firebase Console > Project Settings > General > Your apps
# https://console.firebase.google.com/

EXPO_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
EXPO_PUBLIC_FIREBASE_APP_ID=your-app-id

# ===========================================
# Google OAuth Configuration
# ===========================================
# Get this from Firebase Console > Authentication > Sign-in method > Google
# Use the Web client ID from "Web SDK configuration"

EXPO_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ===========================================
# Error Tracking - Sentry (Optional)
# ===========================================
# Get these from https://sentry.io after creating a React Native project
# Leave EXPO_PUBLIC_SENTRY_DSN blank to disable error tracking

EXPO_PUBLIC_SENTRY_DSN=
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=your-sentry-project

# ===========================================
# AdMob Configuration
# ===========================================
# Get Ad Unit IDs from Google AdMob Console: https://admob.google.com
# Note: App IDs are configured in app.json
# The values below are Google's TEST AD UNIT IDs - safe for development
# Replace with your real Ad Unit IDs for production builds

# Banner Ad Unit IDs
EXPO_PUBLIC_ADMOB_BANNER_ID_IOS=ca-app-pub-3940256099942544/2934735716
EXPO_PUBLIC_ADMOB_BANNER_ID_ANDROID=ca-app-pub-3940256099942544/6300978111

# Interstitial Ad Unit IDs
EXPO_PUBLIC_ADMOB_INTERSTITIAL_ID_IOS=ca-app-pub-3940256099942544/4411468910
EXPO_PUBLIC_ADMOB_INTERSTITIAL_ID_ANDROID=ca-app-pub-3940256099942544/1033173712

# Rewarded Ad Unit IDs
EXPO_PUBLIC_ADMOB_REWARDED_ID_IOS=ca-app-pub-3940256099942544/1712485313
EXPO_PUBLIC_ADMOB_REWARDED_ID_ANDROID=ca-app-pub-3940256099942544/5224354917
