{
  "name": "playbeacon-mobile",
  "version": "1.0.0",
  "main": "index.js",
  "description": "PlayBeacon Mobile App - Discover your next favorite Roblox game",
  "expo": {
    "install": {
      "exclude": ["@react-native-async-storage/async-storage"]
    }
  },
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "setup:sounds": "node scripts/download-placeholder-sounds.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "e2e:build:ios": "detox build --configuration ios.sim.debug",
    "e2e:build:android": "detox build --configuration android.emu.debug",
    "e2e:test:ios": "detox test --configuration ios.sim.debug",
    "e2e:test:android": "detox test --configuration android.emu.debug",
    "e2e:test": "detox test",
    "firestore:deploy": "firebase deploy --only firestore:rules"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "1.24.0",
    "@react-native-community/netinfo": "11.4.1",
    "@react-native-community/slider": "5.0.1",
    "@react-navigation/bottom-tabs": "^7.8.11",
    "@react-navigation/native": "^7.1.24",
    "@react-navigation/stack": "^7.6.11",
    "@sentry/react-native": "~7.2.0",
    "axios": "^1.13.2",
    "expo": "~54.0.29",
    "expo-auth-session": "^7.0.10",
    "expo-av": "~16.0.8",
    "expo-build-properties": "^1.0.10",
    "expo-dev-client": "~6.0.20",
    "expo-haptics": "~15.0.8",
    "expo-linear-gradient": "~15.0.8",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-tracking-transparency": "~6.0.8",
    "expo-web-browser": "^15.0.10",
    "firebase": "^12.6.0",
    "lottie-react-native": "~7.3.1",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-app-intro-slider": "^4.0.4",
    "react-native-confetti-cannon": "^1.5.2",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-google-mobile-ads": "^16.0.0",
    "react-native-iap": "^14.4.47",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "^5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-worklets": "0.5.1"
  },
  "private": true,
  "devDependencies": {
    "@testing-library/react-native": "^12.4.3",
    "@types/react": "~19.1.10",
    "detox": "^20.14.0",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.16",
    "react-test-renderer": "19.1.0",
    "typescript": "~5.9.2"
  }
}
