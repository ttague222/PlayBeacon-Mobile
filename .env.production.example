# PlayBeacon Mobile App - Production Environment
# INSTRUCTIONS: Copy this file to .env.production and fill in your production values

# Environment
APP_ENV=production

# Production API Service (Cloud Run)
# Current production: https://playbeacon-api-prod-346141384720.us-central1.run.app/api
EXPO_PUBLIC_API_BASE_URL=https://playbeacon-api-prod-346141384720.us-central1.run.app/api

# Firebase Configuration (Create a separate production Firebase project!)
EXPO_PUBLIC_FIREBASE_API_KEY=your_production_api_key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-production-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-production-project
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-production-project.firebasestorage.app
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
EXPO_PUBLIC_FIREBASE_APP_ID=your_app_id

# Google OAuth Configuration (Production OAuth client)
EXPO_PUBLIC_GOOGLE_CLIENT_ID=your_production_google_client_id

# Sentry Configuration (REQUIRED for production - error tracking)
# Get this from https://sentry.io after creating a project
EXPO_PUBLIC_SENTRY_DSN=your_production_sentry_dsn

# EAS Project ID (from Expo Application Services)
EAS_PROJECT_ID=your_eas_project_id
